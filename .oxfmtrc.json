{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "experimentalTailwindcss": {
    "functions": ["tv", "twMerge", "twJoin"]
  },
  "trailingComma": "all",
  "tabWidth": 2,
  "semi": false,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "arrowParens": "avoid",
  "printWidth": 100,
  "ignorePatterns": [
    "**/node_modules",
    "**/.next",
    "**/*.md",
    "**/*.mdx",
    "**/*.json",
    "**/*.yaml",
    "**/*.yml",
    "**/.wrangler"
  ]
}
