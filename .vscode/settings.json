{
  "workbench.editor.customLabels.patterns": {
    "**/app/**/page.tsx": "${dirname} - Page",
    "**/app/**/layout.tsx": "${dirname} - Layout",
    "**/app/**/route.{ts,tsx}": "${dirname} - Route"
  },

  // Formatter
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",

  // Tailwind
  "tailwindCSS.classFunctions": ["tv", "twMerge", "twJoin"],

  // Linter
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always"
  },
  "oxc.typeAware": true,

  "files.associations": {
    "turbo.json": "jsonc",
    ".oxfmtrc.json": "jsonc",
    ".oxlintrc.json": "jsonc",
    "apps/trpfrog.net/src/app/globals.css": "tailwindcss",
    "apps/admin/src/app/globals.css": "tailwindcss"
  }
}
