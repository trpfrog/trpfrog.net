{
  "extends": "@trpfrog.net/config-typescript/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@blog/*": ["./src/app/blog/*"]
    },
    "types": ["@testing-library/jest-dom", "vitest/importMeta"]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "tools/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
