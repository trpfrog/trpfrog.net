{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "extends": [
    "./base.json"
  ],
  "plugins": [
    "nextjs"
  ],
  "ignorePatterns": [
    "out",
    "dist",
    "build",
    "coverage",
    ".wrangler",
    ".next",
    "next-env.d.ts"
  ],
  "rules": {
    "nextjs/no-img-element": "off"
  },
  "overrides": [
    {
      "files": [
        "**/{page,layout,route,loading,not-found,opengraph-image,proxy}.{js,jsx,ts,tsx}",
      ],
      "rules": {
        "eslint-core/no-restricted-exports": "off"
      }
    }
  ]
}
