{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "unicorn",
    "typescript",
    "node",
    "vitest",
    "import",
    "promise",
    "jsdoc",
    "oxc"
  ],
  "jsPlugins": [
    {
      "name": "eslint-core",
      "specifier": "./js-plugins/eslint-core.cjs"
    }
  ],
  "ignorePatterns": [
    "out",
    "dist",
    "build",
    "coverage",
    ".wrangler"
  ],
  "rules": {
    "eslint/no-unused-vars": [
      "error",
      {
        "args": "all",
        "argsIgnorePattern": "^_",
        "caughtErrors": "all",
        "caughtErrorsIgnorePattern": "^_",
        "destructuredArrayIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "ignoreRestSiblings": true
      }
    ],
    "eslint-core/no-restricted-exports": [
      "error",
      {
        "restrictDefaultExports": {
          "direct": true,
          "named": true,
          "defaultFrom": true,
          "namedFrom": true,
          "namespaceFrom": true
        }
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/{*.config}.{mjs,cjs,js,jsx,ts,mts,cts,tsx}",
        "**/{vitest.*}.{mjs,cjs,js,jsx,ts,mts,cts,tsx}",
      ],
      "rules": {
        "eslint-core/no-restricted-exports": "off"
      }
    }
  ]
}
