{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "unicorn",
    "typescript",
    "node",
    "vitest",
    "import",
    "promise",
    "jsdoc",
    "oxc"
  ],
  "jsPlugins": [
    {
      "name": "eslint-core",
      "specifier": "./js-plugins/eslint-core.cjs"
    },
    {
      "name": "unused-imports",
      "specifier": "eslint-plugin-unused-imports"
    },
    {
      "name": "eslint-n",
      "specifier": "eslint-plugin-n"
    },
    {
      "name": "ts-eslint",
      "specifier": "@typescript-eslint/eslint-plugin"
    }
  ],
  "ignorePatterns": [
    "out",
    "dist",
    "build",
    "coverage",
    ".wrangler"
  ],
  "rules": {
    "eslint/no-unused-vars": "off",
    "ts-eslint/no-unused-vars": [
      "error",
      {
        "args": "all",
        "argsIgnorePattern": "^_",
        "caughtErrors": "all",
        "caughtErrorsIgnorePattern": "^_",
        "destructuredArrayIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "ignoreRestSiblings": true
      }
    ],
    "unused-imports/no-unused-imports": "error",
    "eslint-n/no-process-env": [
      "error",
      {
        "allowedVariables": [
          "NODE_ENV"
        ]
      }
    ],
    "eslint-core/no-restricted-properties": [
      "error",
      {
        "object": "v",
        "property": "parse",
        "message": "Use @trpfrog.net/utils's `validate` or `validateUnknown` instead."
      },
      {
        "object": "v",
        "property": "safeParse",
        "message": "Use @trpfrog.net/utils's `safeValidate` or `safeValidateUnknown` instead."
      }
    ],
    "ts-eslint/no-restricted-types": [
      "error",
      {
        "types": {
          "v.InferInput": {
            "message": "Use `@trpfrog.net/utils`'s `InferSchemaInput` instead."
          },
          "v.InferOutput": {
            "message": "Use `@trpfrog.net/utils`'s `InferSchemaOutput` instead."
          }
        }
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/*.{js,ts,mjs,cjs,jsx,tsx,mts,cts}"
      ],
      "rules": {
        "eslint-core/no-restricted-exports": [
          "error",
          {
            "restrictDefaultExports": {
              "direct": true,
              "named": true,
              "defaultFrom": true,
              "namedFrom": true,
              "namespaceFrom": true
            }
          }
        ]
      }
    },
    {
      "files": [
        "**/*.config.{mjs,cjs,js,jsx,ts,mts,cts,tsx}"
      ],
      "rules": {
        "eslint-core/no-restricted-exports": "off",
        "eslint-n/no-process-env": "off"
      },
      "env": {
        "node": true
      }
    },
    {
      "files": [
        "**/vitest.{mjs,cjs,js,jsx,ts,mts,cts,tsx}",
        "**/vitest.*.{mjs,cjs,js,jsx,ts,mts,cts,tsx}"
      ],
      "rules": {
        "eslint-core/no-restricted-exports": "off"
      }
    },
    {
      "files": [
        ".storybook/**/*.{mjs,cjs,js,jsx,ts,mts,cts,tsx}"
      ],
      "rules": {
        "eslint-core/no-restricted-exports": "off"
      }
    }
  ]
}
